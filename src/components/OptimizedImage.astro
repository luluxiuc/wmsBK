---
import { Image } from 'astro:assets';

interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
}

const { src, alt, width = 800, height = 600, class: className = '' } = Astro.props;

// 检查是否为远程图片
const isRemote = src.startsWith('http');
---

{isRemote ? (
  <img 
    src={src} 
    alt={alt} 
    width={width}
    height={height}
    class={className}
    loading="lazy"
    decoding="async"
  />
) : (
  <Image 
    src={src} 
    alt={alt} 
    width={width}
    height={height}
    class={className}
    format="webp"
    quality={80}
  />
)}
