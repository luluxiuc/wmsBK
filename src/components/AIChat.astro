---
// AI 聊天组件
// 预设问答系统，让用户通过对话了解我
---

<div class="ai-chat-container">
  <div class="chat-header">
    <div class="chat-avatar">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 2a3 3 0 013 3v7a3 3 0 01-3 3 3 3 0 01-3-3V5a3 3 0 013-3z"/>
        <path d="M19 10v2a7 7 0 01-14 0v-2"/>
        <line x1="12" y1="19" x2="12" y2="23"/>
        <line x1="8" y1="23" x2="16" y2="23"/>
      </svg>
    </div>
    <div class="chat-info">
      <h3 class="chat-title">AI 助手</h3>
      <p class="chat-status">
        <span class="status-dot"></span>
        在线 - 问我关于 wms 的任何问题
      </p>
    </div>
  </div>

  <div class="chat-messages" id="chat-messages">
    <div class="message ai-message">
      <div class="message-avatar ai-avatar">🤖</div>
      <div class="message-content">
        <p>你好！我是 wms 的 AI 助手。想了解关于我的什么事情呢？你可以问我：</p>
        <ul class="suggested-questions">
          <li>"你是谁？"</li>
          <li>"你会什么技能？"</li>
          <li>"你的项目经历？"</li>
          <li>"怎么联系你？"</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="chat-input-area">
    <div class="quick-questions">
      <button class="quick-btn" data-question="你是谁？">你是谁？</button>
      <button class="quick-btn" data-question="你的技能？">你的技能？</button>
      <button class="quick-btn" data-question="你的项目？">你的项目？</button>
    </div>
    <div class="input-wrapper">
      <input 
        type="text" 
        class="chat-input" 
        id="chat-input" 
        placeholder="输入你想了解的问题..."
        autocomplete="off"
      />
      <button class="send-btn" id="send-btn" aria-label="发送">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="22" y1="2" x2="11" y2="13"/>
          <polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  .ai-chat-container {
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    display: flex;
    flex-direction: column;
    max-height: 600px;
  }

  /* Header */
  .chat-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 20px 24px;
    background: rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .chat-avatar {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #60A5FA, #7C3AED);
    border-radius: 16px;
    color: white;
  }

  .chat-info {
    flex: 1;
  }

  .chat-title {
    font-size: 18px;
    font-weight: 700;
    color: #F8FAFC;
    margin: 0;
  }

  .chat-status {
    font-size: 13px;
    color: #94A3B8;
    margin: 4px 0 0;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    background: #10B981;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  /* Messages */
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-height: 400px;
  }

  .message {
    display: flex;
    gap: 12px;
    animation: fadeInUp 0.3s ease;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .user-message {
    flex-direction: row-reverse;
  }

  .message-avatar {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    flex-shrink: 0;
    font-size: 16px;
  }

  .ai-avatar {
    background: linear-gradient(135deg, #60A5FA, #7C3AED);
  }

  .user-avatar {
    background: rgba(255, 255, 255, 0.1);
  }

  .message-content {
    max-width: 80%;
    padding: 14px 18px;
    border-radius: 18px;
    font-size: 15px;
    line-height: 1.6;
    color: #F8FAFC;
  }

  .ai-message .message-content {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom-left-radius: 4px;
  }

  .user-message .message-content {
    background: linear-gradient(135deg, #3B82F6, #7C3AED);
    border-bottom-right-radius: 4px;
  }

  .suggested-questions {
    margin: 12px 0 0;
    padding-left: 18px;
    color: #CBD5E1;
  }

  .suggested-questions li {
    margin: 6px 0;
    cursor: pointer;
    transition: color 0.2s;
  }

  .suggested-questions li:hover {
    color: #60A5FA;
  }

  /* Typing indicator */
  .typing-indicator {
    display: flex;
    gap: 4px;
    padding: 8px 0;
  }

  .typing-indicator span {
    width: 8px;
    height: 8px;
    background: #94A3B8;
    border-radius: 50%;
    animation: typing 1.4s infinite;
  }

  .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
  .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes typing {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-10px); }
  }

  /* Input Area */
  .chat-input-area {
    padding: 20px 24px;
    background: rgba(0, 0, 0, 0.2);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .quick-questions {
    display: flex;
    gap: 8px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .quick-btn {
    padding: 8px 14px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    color: #CBD5E1;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .quick-btn:hover {
    background: rgba(96, 165, 250, 0.2);
    border-color: rgba(96, 165, 250, 0.3);
    color: #60A5FA;
  }

  .input-wrapper {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .chat-input {
    flex: 1;
    padding: 14px 18px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    color: #F8FAFC;
    font-size: 15px;
    outline: none;
    transition: all 0.2s;
  }

  .chat-input::placeholder {
    color: #64748B;
  }

  .chat-input:focus {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(96, 165, 250, 0.5);
    box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.1);
  }

  .send-btn {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #3B82F6, #7C3AED);
    border: none;
    border-radius: 16px;
    color: white;
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .send-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 8px 20px rgba(59, 130, 246, 0.4);
  }

  .send-btn:active {
    transform: scale(0.95);
  }

  /* Scrollbar */
  .chat-messages::-webkit-scrollbar {
    width: 6px;
  }

  .chat-messages::-webkit-scrollbar-track {
    background: transparent;
  }

  .chat-messages::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.2);
    border-radius: 3px;
  }

  .chat-messages::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.3);
  }
</style>

<script>
  // 预设问答知识库
  const knowledgeBase = {
    '你是谁': {
      keywords: ['你是谁', '你是', '介绍', 'about', 'who are you'],
      answer: `你好！我是 **wms**，一名高中生，也是编程爱好者和 AI 应用学习者。

我正在探索技术与设计的交叉点，喜欢构建优雅且实用的数字产品。

这个网站是我的数字花园，记录我的学习、思考和创作。`
    },
    '技能': {
      keywords: ['技能', '会什么', '技术栈', 'skills', '技术'],
      answer: `我的技能包括：

**前端开发**
• HTML / CSS / JavaScript
• Astro / React / Vue
• Tailwind CSS

**编程语言**
• TypeScript / Python
• 正在学习 Rust

**AI 应用**
• Prompt Engineering
• AI 工具集成
• 自动化工作流

**设计**
• UI/UX 设计基础
• Figma`
    },
    '项目': {
      keywords: ['项目', '作品', 'projects', 'portfolio', '做过什么'],
      answer: `我的一些项目：

**个人网站** (本项目)
• 使用 Astro + Tailwind CSS 构建
• 宇宙主题设计，毛玻璃效果
• 集成 AI 聊天功能

**更多项目**
请访问「作品」页面查看完整项目列表！`
    },
    '联系': {
      keywords: ['联系', '联系方式', 'contact', '怎么找你', 'qq', '邮箱'],
      answer: `你可以通过以下方式联系我：

**QQ**: 2121815491

**GitHub**: github.com/luluxiuc

欢迎交流技术、学习或任何有趣的话题！`
    },
    '博客': {
      keywords: ['博客', '文章', 'blog', '写作', '写过'],
      answer: `我会不定期在博客分享：

• 技术学习笔记
• AI 应用探索
• 个人成长思考
• 项目开发经验

欢迎阅读和交流！`
    },
    '学习': {
      keywords: ['学习', '怎么学', '学习方法', 'study', 'learn'],
      answer: `我的学习理念：

**实践优先**
• 通过项目驱动学习
• 做中学，学中做

**AI 辅助**
• 善用 AI 工具加速学习
• 但保持独立思考

**持续迭代**
• 定期复盘和总结
• 构建知识体系

我相信：认真思考过的人，必须自己选择怎么活。`
    },
    '爱好': {
      keywords: ['爱好', '兴趣', '喜欢', 'hobby', '平时'],
      answer: `我的兴趣爱好：

• 💻 编程和技术探索
• 📚 阅读（技术、哲学、科幻）
• 🎮 游戏（独立游戏、Galgame）
• 🎵 音乐（电子、纯音乐）
• ✍️ 写作和思考记录

我相信技术与艺术的结合能创造美好的事物。`
    },
    '目标': {
      keywords: ['目标', '梦想', '规划', '未来', 'goal', 'dream'],
      answer: `我的目标：

**短期**
• 深入学习前端技术
• 掌握 AI 应用开发
• 持续输出优质内容

**长期**
• 成为全栈开发者
• 创造有价值的产品
• 保持终身学习

我不太相信"标准人生"，但我相信认真思考过的人，必须自己选择怎么活。`
    }
  };

  // 默认回复
  const defaultAnswer = `抱歉，我可能没有完全理解你的问题。你可以尝试问我：

• "你是谁？"
• "你的技能？"
• "你的项目？"
• "怎么联系你？"
• "你的学习方法？"

或者直接点击上方的快捷问题按钮！`;

  // 查找匹配的答案
  function findAnswer(input: string): string {
    const lowerInput = input.toLowerCase();
    
    for (const key in knowledgeBase) {
      const item = knowledgeBase[key as keyof typeof knowledgeBase];
      if (item.keywords.some(keyword => lowerInput.includes(keyword.toLowerCase()))) {
        return item.answer;
      }
    }
    
    return defaultAnswer;
  }

  // DOM 元素
  const messagesContainer = document.getElementById('chat-messages');
  const chatInput = document.getElementById('chat-input') as HTMLInputElement;
  const sendBtn = document.getElementById('send-btn');
  const quickBtns = document.querySelectorAll('.quick-btn');

  // 添加消息
  function addMessage(content: string, isUser: boolean) {
    const messageDiv = document.createElement('div');
    messageDiv.className = `message ${isUser ? 'user-message' : 'ai-message'}`;
    
    const avatar = document.createElement('div');
    avatar.className = `message-avatar ${isUser ? 'user-avatar' : 'ai-avatar'}`;
    avatar.textContent = isUser ? '👤' : '🤖';
    
    const contentDiv = document.createElement('div');
    contentDiv.className = 'message-content';
    contentDiv.innerHTML = content.replace(/\n/g, '<br>');
    
    messageDiv.appendChild(avatar);
    messageDiv.appendChild(contentDiv);
    messagesContainer?.appendChild(messageDiv);
    
    // 滚动到底部
    messagesContainer?.scrollTo({
      top: messagesContainer.scrollHeight,
      behavior: 'smooth'
    });
  }

  // 添加打字指示器
  function addTypingIndicator() {
    const indicator = document.createElement('div');
    indicator.className = 'message ai-message typing';
    indicator.id = 'typing-indicator';
    
    indicator.innerHTML = `
      <div class="message-avatar ai-avatar">🤖</div>
      <div class="message-content">
        <div class="typing-indicator">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </div>
    `;
    
    messagesContainer?.appendChild(indicator);
    messagesContainer?.scrollTo({
      top: messagesContainer.scrollHeight,
      behavior: 'smooth'
    });
  }

  // 移除打字指示器
  function removeTypingIndicator() {
    const indicator = document.getElementById('typing-indicator');
    indicator?.remove();
  }

  // 发送消息
  function sendMessage() {
    const message = chatInput?.value.trim();
    if (!message) return;
    
    // 添加用户消息
    addMessage(message, true);
    chatInput.value = '';
    
    // 显示打字指示器
    addTypingIndicator();
    
    // 模拟 AI 思考时间
    setTimeout(() => {
      removeTypingIndicator();
      const answer = findAnswer(message);
      addMessage(answer, false);
    }, 800 + Math.random() * 600);
  }

  // 事件监听
  sendBtn?.addEventListener('click', sendMessage);
  
  chatInput?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      sendMessage();
    }
  });

  // 快捷问题按钮
  quickBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const question = btn.getAttribute('data-question');
      if (question && chatInput) {
        chatInput.value = question;
        sendMessage();
      }
    });
  });

  // 建议问题点击
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.tagName === 'LI' && target.closest('.suggested-questions')) {
      const question = target.textContent?.replace(/"/g, '') || '';
      if (chatInput) {
        chatInput.value = question;
        sendMessage();
      }
    }
  });
</script>
