---
const currentYear = new Date().getFullYear();
---

<footer class="bg-cosmos-900 border-t border-cosmos-600 py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Brand -->
      <div class="space-y-4">
        <a href="/" class="flex items-center gap-2 text-2xl font-bold text-star-100">
          <span class="w-10 h-10 bg-gradient-to-br from-sky-400 to-nebula-400 rounded-xl flex items-center justify-center text-cosmos-800 font-black">W</span>
        </a>
        <p class="text-star-300 max-w-xs">
          构建优雅且实用的数字产品，专注于前端开发与用户体验设计。
        </p>
      </div>

      <!-- Social -->
      <div>
        <h3 class="text-lg font-semibold mb-4 text-star-100">联系我</h3>
        <div class="flex gap-4">
          <!-- GitHub -->
          <a
            href="https://github.com/luluxiuc"
            target="_blank"
            rel="noopener noreferrer"
            class="w-14 h-14 bg-cosmos-700 rounded-xl flex items-center justify-center text-star-300 hover:bg-gradient-to-br hover:from-sky-400 hover:to-nebula-400 hover:text-cosmos-800 transition-all duration-150 border border-cosmos-600"
            aria-label="GitHub"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
          </a>

          <!-- Email - Copy to clipboard -->
          <button
            id="email-copy-btn"
            class="copy-btn w-14 h-14 bg-cosmos-700 rounded-xl flex items-center justify-center text-star-300 hover:bg-gradient-to-br hover:from-sky-400 hover:to-nebula-400 hover:text-cosmos-800 transition-all duration-150 relative border border-cosmos-600"
            aria-label="Email"
            data-copy-text="2121815491@qq.com"
          >
            <!-- Email Icon -->
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <!-- Tooltip -->
            <span class="copy-tooltip absolute -top-10 left-1/2 -translate-x-1/2 px-3 py-1 bg-gradient-to-r from-sky-400 to-nebula-400 text-cosmos-800 text-sm font-semibold rounded-lg opacity-0 pointer-events-none transition-opacity duration-200 whitespace-nowrap">
              已复制
            </span>
          </button>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-12 pt-8 border-t border-cosmos-600 text-center text-star-400">
      <p>&copy; {currentYear} wms. All rights reserved.</p>
    </div>
  </div>
</footer>

<script>
  // Copy to clipboard functionality
  document.querySelectorAll('.copy-btn').forEach(btn => {
    const textToCopy = btn.getAttribute('data-copy-text');
    const tooltip = btn.querySelector('.copy-tooltip');

    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(textToCopy);
        
        // Show tooltip
        if (tooltip) {
          tooltip.classList.remove('opacity-0');
          tooltip.classList.add('opacity-100');
          
          // Hide after 2 seconds
          setTimeout(() => {
            tooltip.classList.remove('opacity-100');
            tooltip.classList.add('opacity-0');
          }, 2000);
        }
      } catch (err) {
        console.error('复制失败:', err);
        
        // Fallback for older browsers
        const textArea = document.createElement('textarea');
        textArea.value = textToCopy;
        textArea.style.position = 'fixed';
        textArea.style.left = '-999999px';
        document.body.appendChild(textArea);
        textArea.select();
        
        try {
          document.execCommand('copy');
          if (tooltip) {
            tooltip.classList.remove('opacity-0');
            tooltip.classList.add('opacity-100');
            setTimeout(() => {
              tooltip.classList.remove('opacity-100');
              tooltip.classList.add('opacity-0');
            }, 2000);
          }
        } catch (err) {
          console.error('复制失败:', err);
        }
        
        document.body.removeChild(textArea);
      }
    });
  });
</script>
