---
// 左侧垂直导航栏组件
// 固定左侧，毛玻璃效果，支持展开/收缩
---

<aside class="sidebar" id="sidebar">
  <div class="sidebar-inner">
    <!-- Logo -->
    <div class="sidebar-header">
      <a href="/" class="logo">
        <span class="logo-icon">W</span>
        <span class="logo-text">wms</span>
      </a>
      <button class="toggle-btn" id="sidebar-toggle" aria-label="切换导航">
        <svg class="icon-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg class="icon-close hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Navigation -->
    <nav class="sidebar-nav" aria-label="主导航">
      <a href="#intro" class="nav-item active" data-section="intro">
        <span class="nav-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </span>
        <span class="nav-label">首页</span>
      </a>
      
      <a href="#about" class="nav-item" data-section="about">
        <span class="nav-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 16v-4M12 8h.01"/>
          </svg>
        </span>
        <span class="nav-label">关于</span>
      </a>
      
      <a href="#chat" class="nav-item" data-section="chat">
        <span class="nav-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
          </svg>
        </span>
        <span class="nav-label">AI对话</span>
      </a>
      
      <a href="#more" class="nav-item" data-section="more">
        <span class="nav-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="1"/>
            <circle cx="19" cy="12" r="1"/>
            <circle cx="5" cy="12" r="1"/>
          </svg>
        </span>
        <span class="nav-label">更多</span>
      </a>

      <div class="nav-divider"></div>

      <a href="/blog/" class="nav-item nav-link-page" data-section="blog">
        <span class="nav-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
        </span>
        <span class="nav-label">博客</span>
      </a>

      <a href="/projects/" class="nav-item nav-link-page" data-section="projects">
        <span class="nav-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="12 2 2 7 12 12 22 7 12 2"/>
            <polyline points="2 17 12 22 22 17"/>
            <polyline points="2 12 12 17 22 12"/>
          </svg>
        </span>
        <span class="nav-label">作品</span>
      </a>

      <a href="/resources/" class="nav-item nav-link-page" data-section="resources">
        <span class="nav-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 19.5A2.5 2.5 0 016.5 17H20"/>
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/>
          </svg>
        </span>
        <span class="nav-label">资源</span>
      </a>
    </nav>
  </div>
</aside>

<!-- 移动端遮罩 -->
<div class="sidebar-overlay" id="sidebar-overlay"></div>

<!-- 移动端底部导航栏 -->
<nav class="mobile-bottom-nav" id="mobile-bottom-nav" aria-label="移动端导航">
  <a href="#intro" class="mobile-nav-item active" data-section="intro">
    <span class="mobile-nav-icon">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
    </span>
    <span class="mobile-nav-label">首页</span>
  </a>
  
  <a href="#chat" class="mobile-nav-item" data-section="chat">
    <span class="mobile-nav-icon">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
      </svg>
    </span>
    <span class="mobile-nav-label">AI对话</span>
  </a>
  
  <a href="#more" class="mobile-nav-item" data-section="more">
    <span class="mobile-nav-icon">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="1"/>
        <circle cx="19" cy="12" r="1"/>
        <circle cx="5" cy="12" r="1"/>
      </svg>
    </span>
    <span class="mobile-nav-label">更多</span>
  </a>
  
  <a href="/blog/" class="mobile-nav-item" data-section="blog">
    <span class="mobile-nav-icon">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
      </svg>
    </span>
    <span class="mobile-nav-label">博客</span>
  </a>
  
  <a href="/projects/" class="mobile-nav-item" data-section="projects">
    <span class="mobile-nav-icon">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polygon points="12 2 2 7 12 12 22 7 12 2"/>
        <polyline points="2 17 12 22 22 17"/>
      </svg>
    </span>
    <span class="mobile-nav-label">作品</span>
  </a>
</nav>

<style>
  .sidebar {
    position: fixed;
    left: 0;
    top: 0;
    height: 100vh;
    width: 72px;
    z-index: 1000;
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: visible;
  }

  .sidebar.expanded {
    width: 200px;
  }

  .sidebar:hover {
    width: 200px;
  }

  .sidebar-inner {
    height: 100%;
    display: flex;
    flex-direction: column;
    background: rgba(15, 23, 42, 0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    padding: 16px 12px;
    transition: all 0.3s ease;
  }

  /* Logo */
  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
    padding: 0 4px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: #F8FAFC;
  }

  .logo-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #60A5FA, #7C3AED);
    border-radius: 12px;
    font-weight: 800;
    font-size: 18px;
    color: white;
    flex-shrink: 0;
  }

  .logo-text {
    font-size: 20px;
    font-weight: 700;
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .sidebar.expanded .logo-text {
    opacity: 1;
    transform: translateX(0);
  }

  /* Toggle Button */
  .toggle-btn {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: #94A3B8;
    cursor: pointer;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .toggle-btn:hover {
    background: rgba(255, 255, 255, 0.15);
    color: #F8FAFC;
  }

  /* Navigation */
  .sidebar-nav {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    border-radius: 12px;
    color: #94A3B8;
    text-decoration: none;
    transition: all 0.2s ease;
    position: relative;
  }

  .nav-item:hover {
    background: rgba(255, 255, 255, 0.05);
    color: #F8FAFC;
  }

  .nav-item.active {
    background: linear-gradient(135deg, rgba(96, 165, 250, 0.2), rgba(124, 58, 237, 0.2));
    color: #60A5FA;
    border: 1px solid rgba(96, 165, 250, 0.3);
  }

  .nav-item.active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 20px;
    background: linear-gradient(180deg, #60A5FA, #7C3AED);
    border-radius: 0 3px 3px 0;
  }

  .nav-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .nav-label {
    font-size: 14px;
    font-weight: 500;
    opacity: 0;
    width: 0;
    overflow: hidden;
    white-space: nowrap;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* 侧边栏悬停时显示所有标签 */
  .sidebar:hover .nav-label {
    opacity: 1;
    width: auto;
    margin-left: 0;
    transform: translateX(0);
  }

  /* 侧边栏整体展开时 */
  .sidebar.expanded .nav-label {
    opacity: 1;
    width: auto;
    margin-left: 0;
    transform: translateX(0);
  }

  /* Nav Divider */
  .nav-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: 12px 0;
  }

  /* Overlay */
  .sidebar-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .sidebar-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  /* Hidden utility */
  .hidden {
    display: none !important;
  }

  /* 移动端底部导航栏 */
  .mobile-bottom-nav {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 64px;
    background: rgba(15, 23, 42, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    z-index: 1000;
    padding: 8px 0;
    padding-bottom: calc(8px + env(safe-area-inset-bottom));
  }

  .mobile-bottom-nav {
    display: flex;
    justify-content: space-around;
    align-items: center;
  }

  .mobile-nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 4px 12px;
    color: #94A3B8;
    text-decoration: none;
    transition: all 0.2s ease;
    border-radius: 12px;
    min-width: 56px;
  }

  .mobile-nav-item:hover {
    color: #F8FAFC;
    background: rgba(255, 255, 255, 0.05);
  }

  .mobile-nav-item.active {
    color: #60A5FA;
  }

  .mobile-nav-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mobile-nav-label {
    font-size: 11px;
    font-weight: 500;
    white-space: nowrap;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .sidebar {
      transform: translateX(-100%);
      width: 200px;
    }

    .sidebar.mobile-open {
      transform: translateX(0);
    }

    .sidebar .nav-label,
    .sidebar .logo-text {
      opacity: 1;
      transform: translateX(0);
    }

    .toggle-btn {
      display: none;
    }

    /* 显示移动端底部导航 */
    .mobile-bottom-nav {
      display: flex;
    }
  }

  /* 更小屏幕优化 */
  @media (max-width: 380px) {
    .mobile-nav-label {
      font-size: 10px;
    }
    
    .mobile-nav-item {
      padding: 4px 8px;
      min-width: 48px;
    }
  }
</style>

<script>
  // Sidebar toggle functionality
  const sidebar = document.getElementById('sidebar');
  const toggleBtn = document.getElementById('sidebar-toggle');
  const overlay = document.getElementById('sidebar-overlay');
  const menuIcon = toggleBtn?.querySelector('.icon-menu');
  const closeIcon = toggleBtn?.querySelector('.icon-close');

  // Check saved state
  const isExpanded = localStorage.getItem('sidebar-expanded') === 'true';
  if (isExpanded) {
    sidebar?.classList.add('expanded');
  }

  // Toggle sidebar
  toggleBtn?.addEventListener('click', () => {
    sidebar?.classList.toggle('expanded');
    const expanded = sidebar?.classList.contains('expanded');
    localStorage.setItem('sidebar-expanded', String(expanded));
  });

  // Mobile menu
  const mobileMenuBtn = document.getElementById('mobile-menu-button');
  mobileMenuBtn?.addEventListener('click', () => {
    sidebar?.classList.toggle('mobile-open');
    overlay?.classList.toggle('active');
  });

  overlay?.addEventListener('click', () => {
    sidebar?.classList.remove('mobile-open');
    overlay?.classList.remove('active');
  });

  // Active section tracking
  const navItems = document.querySelectorAll('.nav-item');
  const mobileNavItems = document.querySelectorAll('.mobile-nav-item');
  const sections = document.querySelectorAll('section[id]');

  function updateActiveNav() {
    const scrollPos = window.scrollY + 100;

    sections.forEach((section, index) => {
      const top = section.offsetTop;
      const height = section.offsetHeight;
      const id = section.getAttribute('id');

      if (scrollPos >= top && scrollPos < top + height) {
        // 更新桌面端导航
        navItems.forEach(item => {
          item.classList.remove('active');
          if (item.getAttribute('data-section') === id) {
            item.classList.add('active');
          }
        });
        
        // 更新移动端导航
        mobileNavItems.forEach(item => {
          item.classList.remove('active');
          if (item.getAttribute('data-section') === id) {
            item.classList.add('active');
          }
        });
      }
    });
  }

  window.addEventListener('scroll', updateActiveNav);
  updateActiveNav();

  // Smooth scroll for anchor links (桌面端)
  navItems.forEach(item => {
    item.addEventListener('click', (e) => {
      handleNavClick(e, item);
    });
  });

  // Smooth scroll for anchor links (移动端)
  mobileNavItems.forEach(item => {
    item.addEventListener('click', (e) => {
      handleNavClick(e, item);
    });
  });

  // 处理导航点击的通用函数
  function handleNavClick(e: Event, item: Element) {
    const href = item.getAttribute('href');
    if (!href) return;
    
    // 如果是页面链接（以 / 开头），不阻止默认行为
    if (href.startsWith('/')) {
      // Close mobile menu
      sidebar?.classList.remove('mobile-open');
      overlay?.classList.remove('active');
      return;
    }
    
    // 锚点链接处理
    e.preventDefault();
    
    // 检查当前是否在首页
    const currentPath = window.location.pathname;
    const isHomePage = currentPath === '/' || currentPath === '/index.html' || currentPath === '';
    
    if (isHomePage) {
      // 在首页，直接滚动到对应位置
      const targetId = href;
      const targetSection = document.querySelector(targetId);
      if (targetSection) {
        targetSection.scrollIntoView({ behavior: 'smooth' });
      }
    } else {
      // 不在首页，先跳转到首页，再滚动到对应位置
      window.location.href = '/' + href;
    }
    
    // Close mobile menu
    sidebar?.classList.remove('mobile-open');
    overlay?.classList.remove('active');
  }

  // 处理页面链接的高亮
  const currentPath = window.location.pathname;
  navItems.forEach(item => {
    const href = item.getAttribute('href');
    if (href?.startsWith('/') && currentPath.startsWith(href)) {
      item.classList.add('active');
    } else if (!href?.startsWith('/')) {
      // 锚点链接根据滚动位置高亮
    }
  });
</script>
