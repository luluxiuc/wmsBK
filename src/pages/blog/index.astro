---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => {
  return data.draft !== true;
});

const sortedPosts = allPosts.sort((a, b) => 
  b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

// 获取所有分类和标签
const allCategories = [...new Set(sortedPosts.map(post => post.data.category))];
const allTags = [...new Set(sortedPosts.flatMap(post => post.data.tags))];

// 统计数据
const totalPosts = sortedPosts.length;
---

<BaseLayout title="博客 - wms" description="wms 的个人博客，记录技术探索与思考">
  <!-- Hero Section -->
  <section class="page-hero">
    <div class="page-hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        博客
      </div>
      <h1 class="hero-title">
        记录技术探索与<span class="gradient-text">思考</span>
      </h1>
      <p class="hero-description">
        分享学习心得、项目经验与技术见解
      </p>
      <div class="hero-stats">
        <div class="stat-item">
          <div class="stat-value">{totalPosts}</div>
          <div class="stat-label">文章</div>
        </div>
        <div class="stat-item">
          <div class="stat-value">{allCategories.length}</div>
          <div class="stat-label">分类</div>
        </div>
        <div class="stat-item">
          <div class="stat-value">{allTags.length}</div>
          <div class="stat-label">标签</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Filter & Search Section -->
  <section class="filter-section">
    <div class="filter-content">
      <!-- Search Bar -->
      <div class="search-wrapper">
        <div class="search-input-wrapper">
          <input
            type="text"
            id="search-input"
            placeholder="搜索文章..."
            class="search-input"
          />
          <div class="search-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/>
              <path d="M21 21l-4.35-4.35"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Category Filter -->
      <div class="filter-buttons">
        <button 
          class="filter-btn active"
          data-filter="all"
        >
          全部
        </button>
        {allCategories.map((category) => (
          <button 
            class="filter-btn"
            data-filter={category}
          >
            {category}
          </button>
        ))}
      </div>

      <!-- Tags -->
      <div class="tag-buttons">
        {allTags.map((tag) => (
          <button 
            class="tag-btn"
            data-tag={tag}
          >
            #{tag}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="posts-section">
    <div class="posts-content">
      <div class="posts-grid" id="posts-grid">
        {sortedPosts.map((post) => (
          <article 
            class="post-card"
            data-category={post.data.category}
            data-tags={post.data.tags.join(',')}
            data-title={post.data.title.toLowerCase()}
            data-description={post.data.description.toLowerCase()}
          >
            <a href={`/blog/${post.slug}/`} class="post-link">
              <!-- Cover -->
              <div class="post-cover">
                <div class="post-emoji">
                  {post.data.category === '技术' && '💻'}
                  {post.data.category === '随笔' && '✍️'}
                  {post.data.category === '思考' && '🤔'}
                  {!['技术', '随笔', '思考'].includes(post.data.category) && '📝'}
                </div>
              </div>

              <!-- Content -->
              <div class="post-content">
                <!-- Category & Date -->
                <div class="post-meta">
                  <span class="post-category">{post.data.category}</span>
                  <span class="post-date">
                    {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </span>
                </div>

                <!-- Title -->
                <h2 class="post-title">
                  {post.data.title}
                </h2>

                <!-- Description -->
                <p class="post-description">
                  {post.data.description}
                </p>

                <!-- Tags -->
                <div class="post-tags">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="post-tag">#{tag}</span>
                  ))}
                </div>

                <!-- Read More -->
                <div class="post-footer">
                  <span class="read-more">
                    阅读全文
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="empty-state hidden">
        <div class="empty-icon">🔍</div>
        <h3 class="empty-title">没有找到相关文章</h3>
        <p class="empty-desc">尝试使用其他关键词搜索或选择其他分类</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero Section */
  .page-hero {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 24px 80px;
    position: relative;
  }

  .page-hero-content {
    text-align: center;
    max-width: 800px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: rgba(96, 165, 250, 0.15);
    border: 1px solid rgba(96, 165, 250, 0.3);
    border-radius: 20px;
    color: #60A5FA;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 24px;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    background: #10B981;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  .hero-title {
    font-size: clamp(40px, 8vw, 64px);
    font-weight: 900;
    color: #F8FAFC;
    margin: 0 0 20px;
    line-height: 1.1;
  }

  .gradient-text {
    background: linear-gradient(135deg, #60A5FA, #7C3AED);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    font-size: 18px;
    color: #94A3B8;
    margin: 0 0 32px;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 48px;
  }

  .stat-item {
    text-align: center;
  }

  .stat-value {
    font-size: 36px;
    font-weight: 800;
    color: #60A5FA;
    line-height: 1;
  }

  .stat-label {
    font-size: 14px;
    color: #64748B;
    margin-top: 4px;
  }

  /* Filter Section */
  .filter-section {
    padding: 32px 24px;
    background: rgba(255, 255, 255, 0.03);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(20px);
  }

  .filter-content {
    max-width: 1000px;
    margin: 0 auto;
  }

  .search-wrapper {
    max-width: 500px;
    margin: 0 auto 24px;
  }

  .search-input-wrapper {
    position: relative;
  }

  .search-input {
    width: 100%;
    padding: 14px 20px 14px 48px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    color: #F8FAFC;
    font-size: 15px;
    outline: none;
    transition: all 0.2s;
  }

  .search-input::placeholder {
    color: #64748B;
  }

  .search-input:focus {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(96, 165, 250, 0.5);
    box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.1);
  }

  .search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: #64748B;
  }

  .filter-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-bottom: 16px;
  }

  .filter-btn {
    padding: 10px 20px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    color: #94A3B8;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-btn:hover {
    background: rgba(255, 255, 255, 0.12);
    color: #F8FAFC;
  }

  .filter-btn.active {
    background: linear-gradient(135deg, #60A5FA, #7C3AED);
    border-color: transparent;
    color: white;
  }

  .tag-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
  }

  .tag-btn {
    padding: 6px 14px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    color: #64748B;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .tag-btn:hover {
    background: rgba(96, 165, 250, 0.15);
    border-color: rgba(96, 165, 250, 0.3);
    color: #60A5FA;
  }

  .tag-btn.active {
    background: rgba(96, 165, 250, 0.2);
    border-color: rgba(96, 165, 250, 0.5);
    color: #60A5FA;
  }

  /* Posts Section */
  .posts-section {
    padding: 60px 24px;
    min-height: 60vh;
  }

  .posts-content {
    max-width: 1200px;
    margin: 0 auto;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 24px;
  }

  @media (max-width: 768px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }

  .post-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .post-card:hover {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(96, 165, 250, 0.3);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .post-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .post-cover {
    height: 180px;
    background: linear-gradient(135deg, rgba(96, 165, 250, 0.2), rgba(124, 58, 237, 0.2));
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .post-emoji {
    font-size: 48px;
    transition: transform 0.3s ease;
  }

  .post-card:hover .post-emoji {
    transform: scale(1.1);
  }

  .post-content {
    padding: 24px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .post-category {
    padding: 4px 12px;
    background: rgba(96, 165, 250, 0.15);
    border: 1px solid rgba(96, 165, 250, 0.3);
    border-radius: 20px;
    color: #60A5FA;
    font-size: 12px;
    font-weight: 500;
  }

  .post-date {
    font-size: 13px;
    color: #64748B;
  }

  .post-title {
    font-size: 18px;
    font-weight: 700;
    color: #F8FAFC;
    margin: 0 0 12px;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.2s;
  }

  .post-card:hover .post-title {
    color: #60A5FA;
  }

  .post-description {
    font-size: 14px;
    color: #94A3B8;
    line-height: 1.6;
    margin: 0 0 16px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .post-tag {
    font-size: 12px;
    color: #64748B;
    background: rgba(255, 255, 255, 0.05);
    padding: 4px 10px;
    border-radius: 8px;
  }

  .post-footer {
    padding-top: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 600;
    color: #60A5FA;
    transition: all 0.2s;
  }

  .post-card:hover .read-more {
    gap: 10px;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 80px 24px;
  }

  .empty-icon {
    font-size: 48px;
    margin-bottom: 16px;
  }

  .empty-title {
    font-size: 20px;
    font-weight: 700;
    color: #F8FAFC;
    margin: 0 0 8px;
  }

  .empty-desc {
    font-size: 14px;
    color: #64748B;
    margin: 0;
  }

  .hidden {
    display: none !important;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
</style>

<script>
  import { 
    FilterManager, 
    setupSearchListener, 
    setupCategoryButtons, 
    setupTagButtons,
    TAG_BUTTON_STYLES,
    updateButtonStyle,
    resetButtonGroupStyles
  } from '../../utils/filterUtils';

  // 获取DOM元素
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const postCards = document.querySelectorAll('.post-card');
  const emptyState = document.getElementById('empty-state');
  const postsGrid = document.getElementById('posts-grid');
  const filterBtns = document.querySelectorAll('.filter-btn');
  const tagBtns = document.querySelectorAll('.tag-btn');

  // 创建筛选管理器
  const filterManager = new FilterManager({
    elements: postCards,
    elementSelector: '.post-card',
    emptyState,
    gridContainer: postsGrid,
    dataExtractor: (element) => ({
      category: element.getAttribute('data-category') || '',
      tags: element.getAttribute('data-tags') || '',
      title: element.getAttribute('data-title') || '',
      description: element.getAttribute('data-description') || ''
    }),
    conditionMatcher: (data, condition) => {
      const matchesCategory = !condition.category || data.category === condition.category;
      const matchesTag = !condition.tag || (data.tags?.includes(condition.tag) ?? false);
      const matchesSearch = !condition.search || 
        data.title?.toLowerCase().includes(condition.search.toLowerCase()) || 
        data.description?.toLowerCase().includes(condition.search.toLowerCase()) ||
        false;
      
      return matchesCategory && matchesTag && matchesSearch;
    }
  });

  // 设置搜索监听器
  setupSearchListener(searchInput, filterManager);

  // 设置分类按钮监听器
  setupCategoryButtons(filterBtns, filterManager, () => {
    // 清除标签按钮样式
    resetButtonGroupStyles(tagBtns, TAG_BUTTON_STYLES.inactive);
  });

  // 设置标签按钮监听器
  setupTagButtons(tagBtns, filterManager);
</script>
