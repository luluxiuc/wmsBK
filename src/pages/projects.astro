---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// 获取所有唯一的标签
const allTags = [...new Set(projects.flatMap(p => p.data.tags))];

// 统计数据
const totalProjects = projects.length;
const totalTags = allTags.length;
---

<BaseLayout title="作品展示 - wms" description="查看 wms 的项目作品集">
  <!-- Hero Section -->
  <section class="page-hero">
    <div class="page-hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        作品展示
      </div>
      <h1 class="hero-title">
        我的 <span class="gradient-text">项目作品集</span>
      </h1>
      <p class="hero-description">
        一些我让它成为现实的想法
      </p>
      <div class="hero-stats">
        <div class="stat-item">
          <div class="stat-value">{totalProjects}</div>
          <div class="stat-label">项目</div>
        </div>
        <div class="stat-item">
          <div class="stat-value">{totalTags}</div>
          <div class="stat-label">标签</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Filter Section -->
  <section class="filter-section">
    <div class="filter-content">
      <div class="filter-buttons" id="filter-container">
        <button 
          class="filter-btn active"
          data-filter="all"
        >
          全部
        </button>
        {allTags.map((tag) => (
          <button 
            class="filter-btn"
            data-filter={tag}
          >
            {tag}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="projects-section">
    <div class="projects-content">
      <div class="projects-grid" id="projects-grid">
        {sortedProjects.map((project) => (
          <article 
            class="project-card"
            data-tags={project.data.tags.join(',')}
          >
            <!-- Cover -->
            <div class="project-cover">
              <div class="project-emoji">🚀</div>
              <div class="project-date">
                {project.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short' })}
              </div>
            </div>

            <!-- Content -->
            <div class="project-content">
              <!-- Tags -->
              <div class="project-tags">
                {project.data.tags.slice(0, 3).map((tag) => (
                  <span class="project-tag">{tag}</span>
                ))}
              </div>

              <!-- Title -->
              <h2 class="project-title">
                {project.data.title}
              </h2>

              <!-- Description -->
              <p class="project-description">
                {project.data.description}
              </p>

              <!-- Links -->
              <div class="project-links">
                {(project.data.demo_url || project.data.demo_hint) && (
                  <a 
                    href={project.data.demo_url || '#'}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="project-link demo-link"
                    data-hint={project.data.demo_hint}
                  >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
                    </svg>
                    在线演示
                  </a>
                )}
                {project.data.github_url && (
                  <a 
                    href={project.data.github_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="project-link"
                  >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                    </svg>
                    源代码
                  </a>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="empty-state hidden">
        <div class="empty-icon">🔍</div>
        <h3 class="empty-title">没有找到相关项目</h3>
        <p class="empty-desc">尝试选择其他标签筛选</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero Section */
  .page-hero {
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 24px 60px;
  }

  .page-hero-content {
    text-align: center;
    max-width: 800px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: rgba(96, 165, 250, 0.15);
    border: 1px solid rgba(96, 165, 250, 0.3);
    border-radius: 20px;
    color: #60A5FA;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 24px;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    background: #10B981;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  .hero-title {
    font-size: clamp(40px, 8vw, 64px);
    font-weight: 900;
    color: #F8FAFC;
    margin: 0 0 20px;
    line-height: 1.1;
  }

  .gradient-text {
    background: linear-gradient(135deg, #60A5FA, #7C3AED);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    font-size: 18px;
    color: #94A3B8;
    margin: 0 0 32px;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 48px;
  }

  .stat-item {
    text-align: center;
  }

  .stat-value {
    font-size: 36px;
    font-weight: 800;
    color: #60A5FA;
    line-height: 1;
  }

  .stat-label {
    font-size: 14px;
    color: #64748B;
    margin-top: 4px;
  }

  /* Filter Section */
  .filter-section {
    padding: 24px;
    background: rgba(255, 255, 255, 0.03);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(20px);
  }

  .filter-content {
    max-width: 1000px;
    margin: 0 auto;
  }

  .filter-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
  }

  .filter-btn {
    padding: 10px 20px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    color: #94A3B8;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-btn:hover {
    background: rgba(255, 255, 255, 0.12);
    color: #F8FAFC;
  }

  .filter-btn.active {
    background: linear-gradient(135deg, #60A5FA, #7C3AED);
    border-color: transparent;
    color: white;
  }

  /* Projects Section */
  .projects-section {
    padding: 60px 24px;
    min-height: 60vh;
  }

  .projects-content {
    max-width: 1200px;
    margin: 0 auto;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 24px;
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }

  .project-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .project-card:hover {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(96, 165, 250, 0.3);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .project-cover {
    height: 180px;
    background: linear-gradient(135deg, rgba(96, 165, 250, 0.2), rgba(124, 58, 237, 0.2));
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .project-emoji {
    font-size: 48px;
    transition: transform 0.3s ease;
  }

  .project-card:hover .project-emoji {
    transform: scale(1.1);
  }

  .project-date {
    position: absolute;
    top: 16px;
    left: 16px;
    padding: 6px 12px;
    background: rgba(15, 23, 42, 0.8);
    backdrop-filter: blur(10px);
    border-radius: 20px;
    font-size: 12px;
    color: #94A3B8;
  }

  .project-content {
    padding: 24px;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }

  .project-tag {
    padding: 4px 10px;
    background: rgba(96, 165, 250, 0.15);
    border: 1px solid rgba(96, 165, 250, 0.3);
    border-radius: 20px;
    color: #60A5FA;
    font-size: 12px;
    font-weight: 500;
  }

  .project-title {
    font-size: 20px;
    font-weight: 700;
    color: #F8FAFC;
    margin: 0 0 12px;
    line-height: 1.4;
    transition: color 0.2s;
  }

  .project-card:hover .project-title {
    color: #60A5FA;
  }

  .project-description {
    font-size: 14px;
    color: #94A3B8;
    line-height: 1.6;
    margin: 0 0 20px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .project-links {
    display: flex;
    gap: 16px;
    padding-top: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 600;
    color: #60A5FA;
    text-decoration: none;
    transition: all 0.2s;
  }

  .project-link:hover {
    color: #93C5FD;
    gap: 10px;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 80px 24px;
  }

  .empty-icon {
    font-size: 48px;
    margin-bottom: 16px;
  }

  .empty-title {
    font-size: 20px;
    font-weight: 700;
    color: #F8FAFC;
    margin: 0 0 8px;
  }

  .empty-desc {
    font-size: 14px;
    color: #64748B;
    margin: 0;
  }

  .hidden {
    display: none !important;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
</style>

<script>
  import { 
    FilterManager, 
    setupCategoryButtons 
  } from '../utils/filterUtils';

  // 获取DOM元素
  const filterBtns = document.querySelectorAll('.filter-btn');
  const projectCards = document.querySelectorAll('.project-card');
  const emptyState = document.getElementById('empty-state');
  const projectsGrid = document.getElementById('projects-grid');

  // 创建筛选管理器
  const filterManager = new FilterManager({
    elements: projectCards,
    elementSelector: '.project-card',
    emptyState,
    gridContainer: projectsGrid,
    dataExtractor: (element) => ({
      tags: element.getAttribute('data-tags') || ''
    }),
    conditionMatcher: (data, condition) => {
      return !condition.category || (data.tags?.includes(condition.category) ?? false);
    }
  });

  // 设置分类按钮监听器
  setupCategoryButtons(filterBtns, filterManager);

  // 处理带提示的演示链接
  const demoLinks = document.querySelectorAll('.demo-link');
  demoLinks.forEach((link) => {
    link.addEventListener('click', (e) => {
      const hint = link.getAttribute('data-hint');
      if (hint) {
        e.preventDefault();
        alert(hint);
      }
    });
  });
</script>
