---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const resources = await getCollection('resources');

// 按分类分组
const groupedResources = resources.reduce((acc, resource) => {
  const category = resource.data.category;
  if (!acc[category]) {
    acc[category] = [];
  }
  acc[category].push(resource);
  return acc;
}, {} as Record<string, typeof resources>);

// 获取所有分类
const categories = Object.keys(groupedResources);

// 统计数据
const totalResources = resources.length;
const totalCategories = categories.length;
---

<BaseLayout title="资源分享 - wms" description="wms 收集整理的各种实用资源">
  <!-- Hero Section -->
  <section class="page-hero">
    <div class="page-hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        资源分享
      </div>
      <h1 class="hero-title">
        实用<span class="gradient-text">资源库</span>
      </h1>
      <p class="hero-description">
        收集整理的各种开发工具、学习资料和设计资源
      </p>
      <div class="hero-stats">
        <div class="stat-item">
          <div class="stat-value">{totalResources}</div>
          <div class="stat-label">资源</div>
        </div>
        <div class="stat-item">
          <div class="stat-value">{totalCategories}</div>
          <div class="stat-label">分类</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Search Section -->
  <section class="search-section">
    <div class="search-content">
      <div class="search-wrapper">
        <div class="search-input-wrapper">
          <input
            type="text"
            id="search-input"
            placeholder="搜索资源..."
            class="search-input"
          />
          <div class="search-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/>
              <path d="M21 21l-4.35-4.35"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Category Filter -->
      <div class="filter-buttons">
        <button 
          class="filter-btn active"
          data-filter="all"
        >
          全部
        </button>
        {categories.map((category) => (
          <button 
            class="filter-btn"
            data-filter={category}
          >
            {category}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Resources Grid -->
  <section class="resources-section">
    <div class="resources-content">
      <div class="resources-grid" id="resources-grid">
        {resources.map((resource) => (
          <article 
            class="resource-card"
            data-category={resource.data.category}
            data-title={(resource.data.resource_name || resource.data.title || '').toLowerCase()}
            data-description={(resource.data.description || resource.data.introduction || '').toLowerCase()}
          >
            <a href={resource.data.download_link || resource.data.url} target="_blank" rel="noopener noreferrer" class="resource-link">
              <!-- Icon -->
              <div class="resource-icon">
                {resource.data.category === '工具' && '🔧'}
                {resource.data.category === '学习' && '📚'}
                {resource.data.category === '设计' && '🎨'}
                {resource.data.category === '教程' && '📖'}
                {!['工具', '学习', '设计', '教程'].includes(resource.data.category) && '📦'}
              </div>

              <!-- Content -->
              <div class="resource-info">
                <div class="resource-header">
                  <h3 class="resource-title">{resource.data.resource_name || resource.data.title}</h3>
                  <span class="resource-category">{resource.data.category}</span>
                </div>
                <p class="resource-description">{resource.data.description || resource.data.introduction}</p>
                <div class="resource-footer">
                  <span class="visit-link">
                    访问资源
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M7 17L17 7M17 7H7M17 7v10"/>
                    </svg>
                  </span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="empty-state hidden">
        <div class="empty-icon">🔍</div>
        <h3 class="empty-title">没有找到相关资源</h3>
        <p class="empty-desc">尝试使用其他关键词搜索或选择其他分类</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero Section */
  .page-hero {
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 24px 60px;
  }

  .page-hero-content {
    text-align: center;
    max-width: 800px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: rgba(96, 165, 250, 0.15);
    border: 1px solid rgba(96, 165, 250, 0.3);
    border-radius: 20px;
    color: #60A5FA;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 24px;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    background: #10B981;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  .hero-title {
    font-size: clamp(40px, 8vw, 64px);
    font-weight: 900;
    color: #F8FAFC;
    margin: 0 0 20px;
    line-height: 1.1;
  }

  .gradient-text {
    background: linear-gradient(135deg, #60A5FA, #7C3AED);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    font-size: 18px;
    color: #94A3B8;
    margin: 0 0 32px;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 48px;
  }

  .stat-item {
    text-align: center;
  }

  .stat-value {
    font-size: 36px;
    font-weight: 800;
    color: #60A5FA;
    line-height: 1;
  }

  .stat-label {
    font-size: 14px;
    color: #64748B;
    margin-top: 4px;
  }

  /* Search Section */
  .search-section {
    padding: 32px 24px;
    background: rgba(255, 255, 255, 0.03);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(20px);
  }

  .search-content {
    max-width: 1000px;
    margin: 0 auto;
  }

  .search-wrapper {
    max-width: 500px;
    margin: 0 auto 24px;
  }

  .search-input-wrapper {
    position: relative;
  }

  .search-input {
    width: 100%;
    padding: 14px 20px 14px 48px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    color: #F8FAFC;
    font-size: 15px;
    outline: none;
    transition: all 0.2s;
  }

  .search-input::placeholder {
    color: #64748B;
  }

  .search-input:focus {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(96, 165, 250, 0.5);
    box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.1);
  }

  .search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: #64748B;
  }

  .filter-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
  }

  .filter-btn {
    padding: 10px 20px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    color: #94A3B8;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-btn:hover {
    background: rgba(255, 255, 255, 0.12);
    color: #F8FAFC;
  }

  .filter-btn.active {
    background: linear-gradient(135deg, #60A5FA, #7C3AED);
    border-color: transparent;
    color: white;
  }

  /* Resources Section */
  .resources-section {
    padding: 60px 24px;
    min-height: 60vh;
  }

  .resources-content {
    max-width: 1000px;
    margin: 0 auto;
  }

  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 20px;
  }

  @media (max-width: 640px) {
    .resources-grid {
      grid-template-columns: 1fr;
    }
  }

  .resource-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .resource-card:hover {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(96, 165, 250, 0.3);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .resource-link {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px;
    text-decoration: none;
    color: inherit;
  }

  .resource-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(96, 165, 250, 0.2), rgba(124, 58, 237, 0.2));
    border-radius: 12px;
    font-size: 24px;
    flex-shrink: 0;
  }

  .resource-info {
    flex: 1;
    min-width: 0;
  }

  .resource-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 8px;
  }

  .resource-title {
    font-size: 16px;
    font-weight: 700;
    color: #F8FAFC;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.2s;
  }

  .resource-card:hover .resource-title {
    color: #60A5FA;
  }

  .resource-category {
    padding: 4px 10px;
    background: rgba(96, 165, 250, 0.15);
    border: 1px solid rgba(96, 165, 250, 0.3);
    border-radius: 20px;
    color: #60A5FA;
    font-size: 11px;
    font-weight: 500;
    flex-shrink: 0;
  }

  .resource-description {
    font-size: 14px;
    color: #94A3B8;
    line-height: 1.6;
    margin: 0 0 12px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .resource-footer {
    display: flex;
    align-items: center;
  }

  .visit-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    color: #60A5FA;
    transition: gap 0.2s;
  }

  .resource-card:hover .visit-link {
    gap: 10px;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 80px 24px;
  }

  .empty-icon {
    font-size: 48px;
    margin-bottom: 16px;
  }

  .empty-title {
    font-size: 20px;
    font-weight: 700;
    color: #F8FAFC;
    margin: 0 0 8px;
  }

  .empty-desc {
    font-size: 14px;
    color: #64748B;
    margin: 0;
  }

  .hidden {
    display: none !important;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
</style>

<script>
  import { 
    FilterManager, 
    setupSearchListener, 
    setupCategoryButtons 
  } from '../utils/filterUtils';

  // 获取DOM元素
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const resourceCards = document.querySelectorAll('.resource-card');
  const emptyState = document.getElementById('empty-state');
  const resourcesGrid = document.getElementById('resources-grid');
  const filterBtns = document.querySelectorAll('.filter-btn');

  // 创建筛选管理器
  const filterManager = new FilterManager({
    elements: resourceCards,
    elementSelector: '.resource-card',
    emptyState,
    gridContainer: resourcesGrid,
    dataExtractor: (element) => ({
      category: element.getAttribute('data-category') || '',
      title: element.getAttribute('data-title') || '',
      description: element.getAttribute('data-description') || ''
    }),
    conditionMatcher: (data, condition) => {
      const matchesCategory = !condition.category || data.category === condition.category;
      const matchesSearch = !condition.search || 
        data.title?.includes(condition.search.toLowerCase()) || 
        data.description?.includes(condition.search.toLowerCase()) ||
        false;
      
      return matchesCategory && matchesSearch;
    }
  });

  // 设置搜索监听器
  setupSearchListener(searchInput, filterManager);

  // 设置分类按钮监听器
  setupCategoryButtons(filterBtns, filterManager);
</script>
