---
import BaseLayout from '../layouts/BaseLayout.astro';
import AIChat from '../components/AIChat.astro';

const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout title="wms - 个人空间" description="通过 AI 对话了解我，探索我的数字花园">
  <!-- Hero / Intro Section -->
  <section id="intro" class="section min-h-screen flex items-center">
    <div class="section-content">
      <div class="intro-card">
        <div class="intro-badge">
          <span class="badge-dot"></span>
          欢迎来到我的数字空间
        </div>
        
        <h1 class="intro-title">
          你好，我是 
          <span class="name-with-avatar">
            <img src="/images/logo.png" alt="wms头像" class="intro-avatar" />
            <span class="gradient-text">wms</span>
          </span>
        </h1>
        
        <p class="intro-description">
          这是一个不一样的个人网站。
        </p>
        
        <div class="intro-purpose">
          <h2>这个网站的目的</h2>
          <p>
            我不太相信"标准人生"。但我相信：认真思考过的人，必须自己选择怎么活。
          </p>
          <p>
            这个网站不是简历，是我留下的思维地图。里面有代码，有文字，有对 AI 的尝试，也有对"人该怎么学习、怎么存在"的追问。
          </p>
          <p>
            如果你读到某句话觉得"这人也这样想过"——欢迎继续探索。
          </p>
        </div>

        <div class="scroll-hint">
          <span>向下滚动，与 AI 对话了解我</span>
          <div class="scroll-arrow">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 5v14M19 12l-7 7-7-7"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="section">
    <div class="section-content">
      <div class="about-grid">
        <div class="about-card">
          <div class="card-icon">👋</div>
          <h3>关于我</h3>
          <p>
            高中生 / 编程爱好者 / AI 应用学习者
          </p>
          <p>
            正在探索技术与设计的交叉点，喜欢构建优雅且实用的数字产品。
          </p>
        </div>

        <div class="about-card">
          <div class="card-icon">💡</div>
          <h3>我的理念</h3>
          <p>
            实践优先，做中学，学中做。
          </p>
          <p>
            善用 AI 工具加速学习，但保持独立思考。
          </p>
        </div>

        <div class="about-card">
          <div class="card-icon">🚀</div>
          <h3>正在做</h3>
          <p>
            深入学习前端技术，掌握 AI 应用开发。
          </p>
          <p>
            持续输出优质内容，构建个人知识体系。
          </p>
        </div>

        <div class="about-card">
          <div class="card-icon">🎯</div>
          <h3>目标</h3>
          <p>
            成为全栈开发者，创造有价值的产品。
          </p>
          <p>
            保持终身学习，认真选择自己的人生。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- AI Chat Section -->
  <section id="chat" class="section">
    <div class="section-content">
      <div class="chat-section-header">
        <h2 class="section-title">
          <span class="title-icon">🤖</span>
          与 AI 对话了解我
        </h2>
        <p class="section-subtitle">
          想更深入地了解我？直接向 AI 助手提问吧！
        </p>
      </div>
      
      <div class="chat-wrapper">
        <AIChat />
      </div>

      <div class="chat-tips">
        <p>💡 提示：你可以问 "你是谁？"、"你的技能？"、"你的项目？"、"怎么联系你？" 等问题</p>
      </div>
    </div>
  </section>

  <!-- More Section -->
  <section id="more" class="section">
    <div class="section-content">
      <div class="people-wansui">
        人民万岁
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Section Base */
  .section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 80px 0;
  }

  .section-content {
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Intro Section */
  .intro-card {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .intro-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: rgba(96, 165, 250, 0.15);
    border: 1px solid rgba(96, 165, 250, 0.3);
    border-radius: 20px;
    color: #60A5FA;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 32px;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    background: #10B981;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  .intro-title {
    font-size: clamp(40px, 8vw, 64px);
    font-weight: 900;
    color: #F8FAFC;
    margin: 0 0 24px;
    line-height: 1.1;
  }

  .gradient-text {
    background: linear-gradient(135deg, #60A5FA, #7C3AED);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .name-with-avatar {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    vertical-align: middle;
  }

  .intro-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid rgba(96, 165, 250, 0.5);
    box-shadow: 0 0 20px rgba(96, 165, 250, 0.3);
    transition: all 0.3s ease;
  }

  .intro-avatar:hover {
    transform: scale(1.1);
    box-shadow: 0 0 30px rgba(96, 165, 250, 0.5);
  }

  @media (max-width: 640px) {
    .intro-avatar {
      width: 48px;
      height: 48px;
    }
  }

  .intro-description {
    font-size: 20px;
    color: #94A3B8;
    margin-bottom: 48px;
  }

  .intro-purpose {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 24px;
    padding: 32px;
    text-align: left;
    margin-bottom: 48px;
  }

  .intro-purpose h2 {
    font-size: 20px;
    font-weight: 700;
    color: #F8FAFC;
    margin: 0 0 20px;
  }

  .intro-purpose p {
    font-size: 16px;
    color: #CBD5E1;
    line-height: 1.8;
    margin: 0 0 16px;
  }

  .intro-purpose p:last-child {
    margin-bottom: 0;
  }

  .scroll-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    color: #64748B;
    font-size: 14px;
  }

  .scroll-arrow {
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-10px); }
    60% { transform: translateY(-5px); }
  }

  /* About Section */
  .about-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 24px;
  }

  .about-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 28px;
    transition: all 0.3s ease;
  }

  .about-card:hover {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(96, 165, 250, 0.3);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .card-icon {
    font-size: 32px;
    margin-bottom: 16px;
  }

  .about-card h3 {
    font-size: 18px;
    font-weight: 700;
    color: #F8FAFC;
    margin: 0 0 12px;
  }

  .about-card p {
    font-size: 14px;
    color: #94A3B8;
    line-height: 1.7;
    margin: 0 0 8px;
  }

  .about-card p:last-child {
    margin-bottom: 0;
  }

  /* Chat Section */
  .chat-section-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .section-title {
    font-size: 36px;
    font-weight: 800;
    color: #F8FAFC;
    margin: 0 0 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .title-icon {
    font-size: 32px;
  }

  .section-subtitle {
    font-size: 18px;
    color: #94A3B8;
    margin: 0;
  }

  .chat-wrapper {
    max-width: 700px;
    margin: 0 auto;
  }

  .chat-tips {
    text-align: center;
    margin-top: 24px;
    color: #64748B;
    font-size: 14px;
  }

  /* More Section */
  .more-content {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 32px;
  }

  @media (max-width: 768px) {
    .more-content {
      grid-template-columns: 1fr;
    }
  }

  .more-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 24px;
    padding: 32px;
  }

  .more-card h3 {
    font-size: 24px;
    font-weight: 700;
    color: #F8FAFC;
    margin: 0 0 24px;
  }

  .thoughts blockquote {
    font-size: 18px;
    font-weight: 600;
    color: #60A5FA;
    margin: 32px 0 16px;
    padding-left: 20px;
    border-left: 3px solid #60A5FA;
  }

  .thoughts blockquote:first-child {
    margin-top: 0;
  }

  .thoughts p {
    font-size: 15px;
    color: #CBD5E1;
    line-height: 1.9;
    margin: 0 0 16px;
  }

  /* Links Card */
  .links-card {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .links-card h3,
  .links-card h4 {
    font-size: 18px;
    font-weight: 700;
    color: #F8FAFC;
    margin: 0;
  }

  .link-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .link-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .link-item:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(96, 165, 250, 0.3);
    transform: translateX(4px);
  }

  .link-icon {
    font-size: 24px;
  }

  .link-info {
    display: flex;
    flex-direction: column;
  }

  .link-title {
    font-size: 15px;
    font-weight: 600;
    color: #F8FAFC;
  }

  .link-desc {
    font-size: 13px;
    color: #64748B;
  }

  .contact-section {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 20px;
  }

  .contact-buttons {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 16px;
  }

  .contact-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    color: #CBD5E1;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
  }

  .contact-btn:hover {
    background: rgba(96, 165, 250, 0.15);
    border-color: rgba(96, 165, 250, 0.3);
    color: #60A5FA;
  }

  /* 人民万岁 */
  .people-wansui {
    font-size: clamp(60px, 15vw, 120px);
    font-weight: 900;
    color: #DC2626;
    text-align: center;
    text-shadow: 0 0 40px rgba(220, 38, 38, 0.5), 0 0 80px rgba(220, 38, 38, 0.3);
    animation: glow 2s ease-in-out infinite alternate;
    letter-spacing: 0.1em;
  }

  @keyframes glow {
    from {
      text-shadow: 0 0 40px rgba(220, 38, 38, 0.5), 0 0 80px rgba(220, 38, 38, 0.3);
    }
    to {
      text-shadow: 0 0 60px rgba(220, 38, 38, 0.8), 0 0 100px rgba(220, 38, 38, 0.5), 0 0 140px rgba(220, 38, 38, 0.3);
    }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
</style>

<script>
  // Copy QQ number
  const copyBtn = document.getElementById('copy-qq');
  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText('2121815491');
      const originalText = copyBtn.innerHTML;
      copyBtn.innerHTML = `
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        已复制！
      `;
      setTimeout(() => {
        copyBtn.innerHTML = originalText;
      }, 2000);
    } catch (err) {
      console.error('复制失败:', err);
    }
  });
</script>
